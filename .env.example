# Copy to .env.local (gitignored) and fill in — see docs/supabase.md
# Server-only. NEVER expose the secret key client-side.
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# Client-side (publishable key is browser-safe; RLS guards the data).
# Auth UI stays hidden while these are unset.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
